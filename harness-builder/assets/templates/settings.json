{
  "permissions": {
    "deny": [
      "Read(./server/.env)",
      "Read(./**/.env*)",
      "Read(./**/secrets/**)",
      "Bash(rm -rf*)",
      "Bash(git push --force*)",
      "Bash(psql*production*)",
      "WebFetch"
    ],
    "allow": [
      "Bash(npm run lint*)",
      "Bash(npm run test*)",
      "Bash(npm run build*)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git add*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx prettier --write \"$CLAUDE_FILE_PATHS\" 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
